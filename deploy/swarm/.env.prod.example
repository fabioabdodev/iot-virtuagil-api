# Production environment used by docker stack deploy on VPS
# File location expected: /opt/iot-virtuagil-api/.env.prod

# Se o deploy for manual no Portainer usando `latest`, prefira:
# APP_RELEASE=latest
# APP_BUILD_TIME=2026-03-16T13:51:00Z
# Se o deploy for automatizado por release, use a tag/sha publicada.
APP_RELEASE=manual
APP_BUILD_TIME=2026-03-14T00:00:00Z
API_IMAGE=ghcr.io/fabioabdodev/iot-virtuagil-api/api:sha-0000000
WEB_IMAGE=ghcr.io/fabioabdodev/iot-virtuagil-api/web:sha-0000000
CORS_ORIGINS=https://monitor.virtuagil.com.br
DATABASE_URL=postgresql://postgres:ENCODED_PASSWORD@db.host:5432/postgres?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:ENCODED_PASSWORD@db.host:5432/postgres?sslmode=require
AUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
AUTH_TOKEN_TTL_HOURS=168
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_LOGIN_RATE_LIMIT_MAX_TRACKED_KEYS=10000
AUTH_LOGIN_LOCK_MINUTES=15
AUTH_PASSWORD_RESET_TTL_MINUTES=60
AUTH_PASSWORD_RETURN_LINK_IN_RESPONSE=false
WEB_APP_URL=https://monitor.virtuagil.com.br
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@virtuagil.com.br
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
DEVICE_API_KEY=change_me
DEVICE_OFFLINE_MINUTES=5
MONITOR_INTERVAL_SECONDS=60
TEMPERATURE_ALERT_COOLDOWN_MINUTES=5
DEVICE_RATE_LIMIT_WINDOW_SECONDS=60
DEVICE_RATE_LIMIT_MAX_REQUESTS=60
DEVICE_RATE_LIMIT_MAX_TRACKED_DEVICES=1000
CONNECTIVITY_FLAP_WINDOW_MINUTES=30
CONNECTIVITY_FLAP_THRESHOLD=3
CONNECTIVITY_INSTABILITY_ALERT_COOLDOWN_MINUTES=60
CACHE_TTL_SECONDS=15
N8N_OFFLINE_WEBHOOK_URL=https://workflows.virtuagil.com.br/webhook/offline
N8N_ONLINE_WEBHOOK_URL=https://workflows.virtuagil.com.br/webhook/device-online
N8N_TEMPERATURE_ALERT_WEBHOOK_URL=https://workflows.virtuagil.com.br/webhook/temperature-alert
N8N_ENERGY_ALERT_WEBHOOK_URL=https://webhookworkflow.virtuagil.com.br/webhook/energy-alert
N8N_ACTUATION_WEBHOOK_URL=
ACTUATION_NOTIFY_ENABLED=false
ACTUATION_NOTIFY_SOURCES=dashboard
ACTUATION_NOTIFY_COOLDOWN_SECONDS=900
ALERT_QUEUE_BATCH_SIZE=10
ALERT_QUEUE_RETRY_MAX=3
ALERT_QUEUE_RETRY_DELAY_MS=1000
LOG_LEVEL=info
