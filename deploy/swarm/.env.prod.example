# Production environment used by docker stack deploy on VPS
# File location expected: /opt/iot-freezer-api/.env.prod

DATABASE_URL=postgresql://postgres:ENCODED_PASSWORD@db.host:5432/postgres?schema=public
DEVICE_API_KEY=change_me
DEVICE_OFFLINE_MINUTES=5
MONITOR_INTERVAL_SECONDS=60
TEMPERATURE_ALERT_COOLDOWN_MINUTES=5
DEVICE_RATE_LIMIT_WINDOW_SECONDS=60
DEVICE_RATE_LIMIT_MAX_REQUESTS=60
DEVICE_RATE_LIMIT_MAX_TRACKED_DEVICES=1000
CACHE_TTL_SECONDS=15
N8N_OFFLINE_WEBHOOK_URL=https://workflows.virtuagil.com.br/webhook/offline
N8N_TEMPERATURE_ALERT_WEBHOOK_URL=https://workflows.virtuagil.com.br/webhook/temperature-alert
ALERT_QUEUE_BATCH_SIZE=10
ALERT_QUEUE_RETRY_MAX=3
ALERT_QUEUE_RETRY_DELAY_MS=1000