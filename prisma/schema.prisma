generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model TemperatureLog {
  id          String   @id @default(uuid())
  deviceId    String
  temperature Float
  createdAt   DateTime @default(now())

  @@index([deviceId, createdAt])
}

model SensorReading {
  id         String   @id @default(uuid())
  deviceId   String
  sensorType String
  value      Float
  unit       String?
  createdAt  DateTime @default(now())

  @@index([deviceId, sensorType, createdAt])
  @@index([deviceId, createdAt])
}

model Device {
  id       String    @id
  clientId String?
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  name     String?
  location String?
  lastSeen DateTime?

  isOffline    Boolean   @default(false)
  offlineSince DateTime?
  lastAlertAt  DateTime?

  // configurable temperature boundaries for each device
  minTemperature Float? // null => no lower limit
  maxTemperature Float? // null => no upper limit

  alertRules AlertRule[]
  alertRuleStates AlertRuleState[]
  actuators Actuator[]

  @@index([clientId])
}

model Client {
  id                String             @id
  name              String
  document          String?
  adminName         String?
  phone             String?
  adminPhone        String?
  alertPhone        String?
  deviceApiKey      String?            @unique
  billingName       String?
  billingPhone      String?
  billingEmail      String?
  status            String             @default("active")
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  devices           Device[]
  alertRules        AlertRule[]
  actuators         Actuator[]
  actuationCommands ActuationCommand[]
  actuationSchedules ActuationSchedule[]
  users             User[]
  modules           ClientModule[]
  moduleItemAccesses ClientModuleItem[]
}

model AlertRule {
  id              String   @id @default(uuid())
  clientId        String
  deviceId        String?
  sensorType      String
  minValue        Float?
  maxValue        Float?
  cooldownMinutes Int      @default(5)
  toleranceMinutes Int     @default(0)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  states AlertRuleState[]

  @@index([clientId])
  @@index([deviceId])
  @@index([sensorType])
}

model AlertRuleState {
  id              String   @id @default(uuid())
  ruleId          String
  deviceId        String
  breachStartedAt DateTime?
  lastTriggeredAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rule   AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  device Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([ruleId, deviceId])
  @@index([ruleId])
  @@index([deviceId])
}

model Actuator {
  id              String             @id
  clientId        String
  deviceId        String?
  name            String
  location        String?
  currentState    String             @default("off")
  lastCommandAt   DateTime?
  lastCommandBy   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  client          Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  device          Device?            @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  commands        ActuationCommand[]
  schedules       ActuationSchedule[]

  @@index([clientId])
  @@index([deviceId])
}

model ActuationCommand {
  id           String   @id @default(uuid())
  actuatorId   String
  clientId     String
  desiredState String
  source       String?
  note         String?
  executedAt   DateTime @default(now())
  actuator     Actuator @relation(fields: [actuatorId], references: [id], onDelete: Cascade)
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([actuatorId, executedAt])
  @@index([clientId, executedAt])
}

model ActuationSchedule {
  id            String   @id @default(uuid())
  clientId      String
  actuatorId    String
  name          String
  weekdays      String[]
  startMinutes  Int
  endMinutes    Int
  timezone      String   @default("America/Sao_Paulo")
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  actuator      Actuator @relation(fields: [actuatorId], references: [id], onDelete: Cascade)
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([actuatorId])
  @@index([enabled])
}

model User {
  id           String   @id @default(uuid())
  clientId     String?
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("operator")
  phone        String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  passwordResetTokens PasswordResetToken[]

  @@index([clientId])
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  purpose    String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, expiresAt])
  @@index([expiresAt])
}

model ClientModule {
  id        String   @id @default(uuid())
  clientId  String
  moduleKey String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, moduleKey])
  @@index([clientId])
}

model ModuleCatalog {
  key         String   @id
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       ModuleCatalogItem[]
}

model ModuleCatalogItem {
  key         String   @id
  moduleKey   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  module      ModuleCatalog @relation(fields: [moduleKey], references: [key], onDelete: Cascade)
  clients     ClientModuleItem[]

  @@index([moduleKey])
}

model ClientModuleItem {
  id       String   @id @default(uuid())
  clientId String
  itemKey  String
  enabled  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  item     ModuleCatalogItem @relation(fields: [itemKey], references: [key], onDelete: Cascade)

  @@unique([clientId, itemKey])
  @@index([clientId])
  @@index([itemKey])
}

model AuditLog {
  id           String   @id @default(uuid())
  clientId     String?
  entityType   String
  entityId     String
  action       String
  fieldName    String?
  previousValue Json?
  nextValue    Json?
  actorUserId  String?
  actorEmail   String?
  actorRole    String?
  actorClientId String?
  createdAt    DateTime @default(now())

  @@index([clientId, createdAt])
  @@index([entityType, entityId, createdAt])
}
